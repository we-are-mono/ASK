+***********************************************************************/
+void sigpppoerelay_Term_Handler(int signum)
+{
+	syslog(LOG_INFO, "%s: entered\n", __func__);
+	cleanSessionsSigterm();
+	remove(PPPOERELAY_PID_FILE_PATH);
+	/* Killing PPPoE-RELAY ........... */
+	exit(EXIT_SUCCESS);
+	
+}
